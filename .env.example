# Copy to .env.local and fill in.
# .env*.local is gitignored. Never commit secrets.

# ----- Supabase (required for auth, RLS, server data access) -----
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGci..."

# Service-role key — server-side only. Used by:
#   - scripts/seed.ts to bypass RLS when seeding the catalog
#   - server-side webhook handlers that need elevated access
# NEVER ship to the client. NEVER commit.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci..."

# Convenience alias the seed script reads (mirrors NEXT_PUBLIC_SUPABASE_URL
# without the Next.js prefix so it works outside the app).
SUPABASE_URL="$NEXT_PUBLIC_SUPABASE_URL"

# ----- Stripe (subscription billing — Phase 3 follow-up) -----
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Price IDs created in the Stripe dashboard (monthly + annual w/ 7-day trial)
STRIPE_PRICE_MONTHLY="price_..."
STRIPE_PRICE_ANNUAL="price_..."

# ----- Analytics + observability (Phase 6) -----
NEXT_PUBLIC_GA4_MEASUREMENT_ID=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
SENTRY_DSN=""

# ----- Receipt OCR (deferred to v1.1) -----
GOOGLE_VISION_CREDENTIALS_JSON=""

# ----- Transactional email (Phase 6) -----
RESEND_API_KEY=""
