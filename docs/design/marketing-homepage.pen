        },
        {
          "type": "frame",
          "id": "spzI6",
          "name": "05 FAQ",
          "width": "fill_container",
          "fill": "#FFFFFF",
          "layout": "vertical",
          "padding": [
            96,
            80
          ],
          "children": [
            {
              "type": "frame",
              "id": "VYik3",
              "name": "faqInner",
              "width": 760,
              "layout": "vertical",
              "gap": 18,
              "children": [
                {
                  "type": "text",
                  "id": "C8I2K9",
                  "fill": "#DC2626",
                  "content": "COMMON QUESTIONS",
                  "fontFamily": "Inter",
                  "fontSize": 11,
                  "fontWeight": "500",
                  "letterSpacing": 1.4
                },
                {
                  "type": "text",
                  "id": "N1VDXY",
                  "fill": "#0F172A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "FAQ",
                  "lineHeight": 1.1,
                  "fontFamily": "Inter",
                  "fontSize": 36,
                  "fontWeight": "800",
                  "letterSpacing": -0.7
                },
                {
                  "type": "frame",
                  "id": "BZvFw",
                  "name": "faqList",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 8,
                  "children": [
                    {
                      "type": "frame",
                      "id": "Prh9l",
                      "name": "q1",
                      "width": "fill_container",
                      "fill": "#FFFFFF",
                      "cornerRadius": 8,
                      "stroke": {
                        "thickness": 1,
                        "fill": "#E2E8F0"
                      },
                      "layout": "vertical",
                      "gap": 10,
                      "padding": [
                        18,
                        22
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "RrdFK",
                          "fill": "#0F172A",
                          "content": "Do I have to shop at Costco?",
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "TCYDu",
                          "fill": "#334155",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The plan is built around 75 Costco staples — pack sizes, quantities, and price expectations all assume Costco. You can substitute equivalents from any warehouse club or large grocery store, but the shopping list won't map 1:1.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "APWPr",
                      "name": "q2",
                      "width": "fill_container",
                      "fill": "#FFFFFF",
                      "cornerRadius": 8,
                      "stroke": {
                        "thickness": 1,
                        "fill": "#E2E8F0"
                      },
                      "layout": "vertical",
                      "gap": 10,
                      "padding": [
                        18,
                        22
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "MlYOP",
                          "fill": "#0F172A",
                          "content": "Will the recipes work for picky kids?",
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "sleMA",
                          "fill": "#334155",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Most of them, yes. The plan leans on familiar shapes like burrito bowls, pasta, stir-fry, chili, all with simple seasonings you can dress up or down. The PDF includes notes on ingredients to swap or skip when you've got a picky eater at the table.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "p9Bmdn",
                      "name": "q3",
                      "width": "fill_container",
                      "fill": "#FFFFFF",
                      "cornerRadius": 8,
                      "stroke": {
                        "thickness": 1,
                        "fill": "#E2E8F0"
                      },
                      "layout": "vertical",
                      "gap": 10,
                      "padding": [
                        18,
                        22
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "q8cFB7",
                          "fill": "#0F172A",
                          "content": "How long does each cook day take?",
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "UCswr",
                          "fill": "#334155",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Cook Day 1 is roughly 3–4 hours of active time on a Sunday afternoon, batching 7 meals. Cook Day 2 is a 60–90 minute mid-week mini, batching the next 7. Reheats are 5–15 minutes on weeknights.\n\nYou can also cook meals a-la-carte, with each meal taking ~20 to 45 minutes in total. ",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "i0HNY",
                      "name": "q4",
                      "width": "fill_container",
                      "fill": "#FFFFFF",
                      "cornerRadius": 8,
                      "stroke": {
                        "thickness": 1,
                        "fill": "#E2E8F0"
                      },
                      "layout": "vertical",
                      "gap": 10,
                      "padding": [
                        18,
                        22
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "L0HWc",
                          "fill": "#0F172A",
                          "content": "What if I'm cooking for 2 instead of 4?",
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "Q07z44",
                          "fill": "#334155",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Halve the protein and starch quantities; produce and condiments are usually fine to keep at full quantity since Costco pack sizes are generous. The free plan doesn't include scaled-down lists — that's for paid subscribers to the full pantry tracking system",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "B6cg14",
                      "name": "q5",
                      "width": "fill_container",
                      "fill": "#FFFFFF",
                      "cornerRadius": 8,
                      "stroke": {
                        "thickness": 1,
                        "fill": "#E2E8F0"
                      },
                      "layout": "vertical",
                      "gap": 10,
                      "padding": [
                        18,
                        22
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "jaCne",
                          "fill": "#0F172A",
                          "content": "Is there a paid version?",
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "S8U1Jl",
                          "fill": "#334155",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Yes,  a full pantry tracking system for $14.99/mo with the full 6-week system (the free 14 dinners plus three more bi-weekly plans = 26 dinners total, with rolling weekly rhythm and pantry-drawdown logic). You'll hear about it in the welcome email sequence.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "GH72r",
                      "name": "q6",
