              "content": "Privacy policy",
              "lineHeight": 1.04,
              "fontFamily": "Inter",
              "fontSize": 56,
              "fontWeight": "800",
              "letterSpacing": -1.5
            },
            {
              "type": "frame",
              "id": "jOrQU",
              "name": "pProse",
              "width": 720,
              "layout": "vertical",
              "gap": 14,
              "children": [
                {
                  "type": "text",
                  "id": "JwfVQ",
                  "fill": "#0F172A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "What we collect",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "Ha6D5",
                  "fill": "#334155",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "When you sign up for the free meal plan, we collect your email address and any UTM parameters present in the URL at the time of sign-up (so we can understand which channels work). That's it — no name, no phone, no payment info, no demographic data.",
                  "lineHeight": 1.65,
                  "fontFamily": "Inter",
                  "fontSize": 15.5,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "OhZOa",
                  "fill": "#0F172A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Where it lives",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "DoaJ3",
                  "fill": "#334155",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Email addresses are stored in Beehiiv, our newsletter platform. Beehiiv hosts the welcome sequence and any future newsletter content.",
                  "lineHeight": 1.65,
                  "fontFamily": "Inter",
                  "fontSize": 15.5,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "FR4Tx",
                  "fill": "#0F172A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Analytics",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "y4DEW",
                  "fill": "#334155",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "We use Google Analytics to measure traffic, signup conversion, and channel attribution. GA4 sets cookies that may identify your browser; it does not collect personally identifying information like your email address.",
                  "lineHeight": 1.65,
                  "fontFamily": "Inter",
                  "fontSize": 15.5,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "gtGLW",
                  "fill": "#0F172A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Sharing",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "liVp2",
                  "fill": "#334155",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "We don't sell, rent, or share your email with third parties. Beehiiv processes it on our behalf as our email service provider; that's the only sharing that happens.",
                  "lineHeight": 1.65,
                  "fontFamily": "Inter",
                  "fontSize": 15.5,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "gSMi3",
                  "fill": "#0F172A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Unsubscribing & deletion",
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "EYAnP",
                  "fill": "#334155",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Every email we send includes a one-click unsubscribe. Unsubscribing removes you from the active list. To request full deletion of your record from Beehiiv, email hi@stockupdinners.com and we'll handle it within 7 days.",
                  "lineHeight": 1.65,
                  "fontFamily": "Inter",
                  "fontSize": 15.5,
                  "fontWeight": "normal"
