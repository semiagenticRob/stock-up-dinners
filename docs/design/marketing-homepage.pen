                      "letterSpacing": 0.6
                    },
                    {
                      "type": "text",
                      "id": "CRdQh",
                      "fill": "#0F172A",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "OVEN ROUND 1 (M09 + M14).  SEASON both pork tenderloins with S+P+garlic powder + olive oil. ROAST at 400°F for 20–25 min until 145°F internal; REST + SLICE. BAKE/AIR-FRY 2 lb Just Bare chunks per package directions.",
                      "lineHeight": 1.55,
                      "fontFamily": "Inter",
                      "fontSize": 12.5,
                      "fontWeight": "500"
                    }
                  ]
                }
              ]
