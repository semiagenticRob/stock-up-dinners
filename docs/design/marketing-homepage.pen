                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "BURRITO BOWLS.  Diced chicken + 2 cans drained black beans + 1 can drained corn → foil pan. Rice → gallon bag (frozen flat). 8 oz shredded cheddar → quart bag. Fresh spinach kept day-of.",
                      "lineHeight": 1.55,
                      "fontFamily": "Inter",
                      "fontSize": 12.5,
                      "fontWeight": "500"
