            80
          ],
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "HwkX0",
              "name": "whyCopy",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 18,
              "children": [
                {
                  "type": "text",
                  "id": "dY2kT",
                  "fill": "#64748B",
                  "content": "WHY WE BUILT THIS",
                  "fontFamily": "Inter",
                  "fontSize": 11,
                  "fontWeight": "500",
                  "letterSpacing": 1.4
                },
                {
                  "type": "text",
                  "id": "PrFKn",
                  "fill": "#0F172A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "The Only Solution for a Busy Family Like Us!",
                  "lineHeight": 1.1,
                  "fontFamily": "Inter",
                  "fontSize": 36,
                  "fontWeight": "800",
                  "letterSpacing": -0.7
                },
                {
                  "type": "text",
                  "id": "DItjX",
                  "fill": "#334155",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "We're busy professionals with kids. \n\nAfter a long day of meetings, nothing was more stressful than getting home and rushing to prep dinner with hungry children prowling the house. Instead of accepting the 4:50PM panic, we decided to do something about it.  \n\nOur kitchen runs on warehouse-club staples and a real life week is two cook windows, not seven.",
                  "lineHeight": 1.65,
                  "fontFamily": "Inter",
                  "fontSize": 15.5,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "lr9ZB",
                  "fill": "#334155",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Free fourteen-day plan now. The full six-week system, with three more bi-weekly plans, lands later. More about the project →",
                  "lineHeight": 1.65,
                  "fontFamily": "Inter",
                  "fontSize": 15.5,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "CUUQS",
              "name": "why/media",
              "width": "fill_container",
              "height": 380,
              "fill": {
                "type": "image",
                "enabled": true,
                "url": "../../web/public/images/family-story.jpg",
                "mode": "fill"
              },
