                    {
                      "type": "text",
                      "id": "Pd25w",
                      "fill": "#0F172A",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "TIKKA MARINADE (M08).  CUT 3 lb chicken breast into chunks. MARINATE in 1 cup yogurt + minced garlic + 1 can tomato paste + garlic powder + salt. SET aside in the fridge for 20+ min while you prep other things.",
                      "lineHeight": 1.55,
                      "fontFamily": "Inter",
                      "fontSize": 12.5,
                      "fontWeight": "500"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "QYijI",
                  "name": "d2ph1s2",
