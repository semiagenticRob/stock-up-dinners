---
export interface Props {
  variant?: 'hero' | 'closing';
  helper?: string;
  buttonLabel?: string;
}
const {
  variant = 'hero',
  helper = 'Free PDF + printable shopping list. No spam — unsubscribe anytime.',
  buttonLabel = 'Get the free plan',
} = Astro.props;

const ctaId = variant === 'hero' ? 'signup' : `signup-${variant}`;
const subscribeUrl = 'https://stockupdinners.beehiiv.com/subscribe';
---
<div class="signup" id={ctaId}>
  <a href={subscribeUrl} class="btn signup__btn" data-signup-link>{buttonLabel}</a>
  <p class="helper signup__helper">{helper}</p>
</div>

<style>
  .signup { display: flex; flex-direction: column; gap: 10px; max-width: 520px; }
  .signup__btn { align-self: flex-start; padding: 14px 22px; }
  .signup__helper { font-size: 12.5px; color: var(--c-muted); margin: 0; }
</style>
