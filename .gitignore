# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
/.next/
/out/

# Vercel
.vercel

# testing / coverage
/coverage
/playwright-report/
/test-results/

# build artifacts
/build
dist/

# debug logs
npm-debug.*
yarn-debug.*
yarn-error.*
.pnpm-debug.log*

# macOS
.DS_Store
*.pem

# local env files (.env stays committable for the deployed prod values
# the team agrees on, but anything ending in .local is ignored)
.env
.env*.local

# typescript build outputs
*.tsbuildinfo
next-env.d.ts

# Tooling caches
.superpowers/
.worktrees/
.playwright-mcp/

# Supabase local emulator scratch
supabase/.temp/
